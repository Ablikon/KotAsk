{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "^/(.*\\.(js|css|svg|ico|png|jpg|jpeg|mp3|json|webmanifest|woff2|woff|ttf))$",
      "dest": "/client/$1"
    },
    {
      "src": "^/gallery/(.*)",
      "dest": "/client/gallery/$1"
    },
    {
      "src": "^/(.*)",
      "dest": "/client/index.html"
    }
  ]
}