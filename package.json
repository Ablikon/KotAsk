{
  "name": "ask-project",
  "version": "1.0.0",
  "description": "Minimal Supportive Digital Space",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd api && node server.js",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd api && npm install && cd ../client && npm install",
    "db:init": "curl http://localhost:3000/api/init-db"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}